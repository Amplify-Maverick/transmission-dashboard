# ---------------------------------------------------------------------------
# transmission-dashboard configuration
#
# Copy this file to `.env` and fill in the values:
#     cp .env.example .env
# `.env` is gitignored, so your secrets never end up in git.
# ---------------------------------------------------------------------------

# ---------- Transmission RPC ----------
# Where transmission-daemon's RPC listens. The defaults match a daemon
# running on the same host with the stock port.
TR_HOST=127.0.0.1
TR_PORT=9091
# RPC username / password — must match rpc-username / rpc-password in the
# daemon's settings.json. Required unless USE_MOCK=true (see below).
TR_USER=
TR_PASS=
# Path to the daemon's settings.json. Only read as a fallback for the tunnel
# indicator on Transmission 4.x; the default suits the Debian/Ubuntu package.
# TR_SETTINGS_FILE=/etc/transmission-daemon/settings.json

# Directory Transmission downloads into. Used for the disk-space widget.
DOWNLOAD_DIR=/var/lib/transmission-daemon/downloads

# ---------- Dashboard login ----------
# Credentials for logging into the dashboard itself. Login stays DISABLED
# (the whole dashboard is inaccessible) until BOTH are set — there are no
# default credentials. Pick your own.
DASHBOARD_USER=
DASHBOARD_PASS=

# ---------- Flask session secret ----------
# Signs the session cookie. Leave this UNSET and the app auto-generates a
# random key on first run and persists it to a gitignored `.flask_secret`
# file (chmod 600), reusing it on later runs. Only set it explicitly if you
# want to pin the key (e.g. share sessions across multiple hosts).
# FLASK_SECRET_KEY=

# ---------- WireGuard / VPN tunnel indicator ----------
# Name of the WireGuard interface Transmission's traffic is bound to. When
# set, the topbar shows a live tunnel-health indicator; leave it blank to
# hide the indicator entirely. The tunnel IP is read live from the interface
# on each check — only the interface name is pinned here.
TUNNEL_IFACE=
# A peer with no handshake in this many seconds is treated as stale/down.
# WG_HANDSHAKE_STALE_SEC=180
# How long a tunnel-status result is cached before the next probe.
# TUNNEL_CHECK_CACHE_TTL=30

# Mullvad VPN account number (16 digits). When set, the torrents page shows
# a days-remaining countdown. Find yours in the Mullvad app under Account.
# MULLVAD_ACCOUNT=

# ---------- Update-available indicator ----------
# When the running checkout is behind its git upstream, the topbar shows an
# "N updates" badge. Enabled by default; set to false to disable.
# UPDATE_CHECK_ENABLED=true
# How long (seconds) an update check is cached before another `git fetch`.
# UPDATE_CHECK_CACHE_TTL=900

# ---------- Development ----------
# Set to true to use the built-in mock Transmission client (no real daemon
# or RPC credentials needed). Great for local UI work.
# USE_MOCK=false
